---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const stack = [
  { 
    text: "Astro", 
    icon: "astro", 
    href: "https://astro.build" 
  },
  { 
    text: "Javascript", 
    icon: "javascript", 
    href: "https://www.javascript.com" 
  },
  { 
    text: "Typescript", 
    icon: "typescript", 
    href: "https://www.typescriptlang.org" 
  },
  { 
    text: "Tailwind", 
    icon: "tailwind", 
    href: "https://tailwindcss.com" 
  },
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- Light Mode: Particles -->
  <div class='absolute inset-0 block dark:hidden'>
    <div id='particles1' class='fixed inset-0'></div>
    <div id='particles2' class='fixed inset-0'></div>
    <div id='particles3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class='absolute inset-0 bg-black hidden dark:block'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>
  
  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div id="planetcont" class='animate absolute inset-0 top-1/4 overflow-hidden'>
      <div id="crescent" class='absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-[100vh] aspect-square rounded-full p-[1px] bg-gradient-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%'>
        <div id="planet" class='w-full h-full bg-white dark:bg-black rounded-full p-[1px] overflow-hidden flex justify-center'>
          <div id="blur" class='w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl'/>
        </div>
      </div>
    </div>
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class='relative w-full h-full flex items-center justify-center'>
        <div class='p-5 text-center'>
          <!-- Night Heron Avatar -->
          <div class='animated flex justify-center mb-4'>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140" class="w-28 h-28 md:w-32 md:h-32">
              <!-- Chubby round body -->
              <ellipse cx="70" cy="85" rx="42" ry="38" fill="#d1d5db"/>
              <!-- White belly/chest -->
              <ellipse cx="70" cy="95" rx="30" ry="28" fill="#f5f5f4"/>
              <!-- Blue-grey wing feathers left -->
              <path d="M28 75 Q22 90 30 108 Q38 95 36 78Z" fill="#6b8fa3"/>
              <!-- Blue-grey wing feathers right -->
              <path d="M112 75 Q118 90 110 108 Q102 95 104 78Z" fill="#6b8fa3"/>
              <!-- Blue-grey back/shoulders -->
              <ellipse cx="70" cy="72" rx="35" ry="18" fill="#7a9bb0"/>
              <!-- Head -->
              <circle cx="70" cy="42" r="26" fill="#d1d5db"/>
              <!-- White face patch -->
              <path d="M50 38 Q55 52 70 56 Q85 52 90 38 Q82 44 70 46 Q58 44 50 38Z" fill="#f5f5f4"/>
              <!-- Dark cap/crown -->
              <path d="M44 38 Q48 16 70 14 Q92 16 96 38 Q88 24 70 22 Q52 24 44 38Z" fill="#1a2332"/>
              <!-- Left eye - angry/grumpy -->
              <ellipse cx="58" cy="40" rx="4.5" ry="4" fill="white"/>
              <circle cx="59" cy="40" r="2.5" fill="#c0392b"/>
              <circle cx="59.5" cy="39.5" r="1.2" fill="#1a1a1a"/>
              <!-- Angry left eyebrow -->
              <line x1="52" y1="33" x2="63" y2="35" stroke="#1a2332" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Right eye - angry/grumpy -->
              <ellipse cx="82" cy="40" rx="4.5" ry="4" fill="white"/>
              <circle cx="81" cy="40" r="2.5" fill="#c0392b"/>
              <circle cx="80.5" cy="39.5" r="1.2" fill="#1a1a1a"/>
              <!-- Angry right eyebrow -->
              <line x1="88" y1="33" x2="77" y2="35" stroke="#1a2332" stroke-width="2.5" stroke-linecap="round"/>
              <!-- Head plumes -->
              <path d="M66 15 Q63 4 58 -2" stroke="#1a2332" stroke-width="2" stroke-linecap="round" fill="none"/>
              <path d="M70 14 Q70 2 72 -4" stroke="#1a2332" stroke-width="2" stroke-linecap="round" fill="none"/>
              <path d="M74 15 Q77 4 82 -2" stroke="#1a2332" stroke-width="2" stroke-linecap="round" fill="none"/>
              <!-- Beak - dark pointy -->
              <path d="M64 48 L70 62 L76 48Z" fill="#2c3e50"/>
              <!-- Tiny feet -->
              <line x1="58" y1="120" x2="55" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="58" y1="120" x2="61" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="82" y1="120" x2="79" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="82" y1="120" x2="85" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <p class='animated text-lg md:text-xl lg:text-2xl font-semibold opacity-75'>
            <span class="lang-zh">你好，我是</span>
            <span class="lang-en hidden">Hello, I am ...</span>
          </p>
          <p class='animated text-2xl md:text-3xl lg:text-4xl font-bold uppercase text-black dark:text-white'>
            Andy J
          </p>
          <p class='animated text-sm md:text-base lg:text-lg opacity-75'>
            <span class="lang-zh">我是一只企鹅，如果你看成了叶鹭，说明你该休息了</span>
            <span class="lang-en hidden">I'm a penguin. If you saw a night heron, you need some rest.</span>
          </p>
          <div id="ctaButtons" class='animated flex flex-wrap gap-4 justify-center mt-5'>
            <a href='/blog' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend'>
              <span class="lang-zh">看看博客</span>
              <span class="lang-en hidden">Read my blog</span>
            </a>
            <a href='/work' class='py-2 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend'>
              <span class="lang-zh">我的经历</span>
              <span class="lang-en hidden">View my work</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article class="lang-zh">
          <p>我是一名<b><i>加密货币运营专家</i></b>、<b><i>社区搭建者</i></b>、<b><i>产品思考者</i></b>、<b><i>AI 工作流探索者</i></b>，也是一名<b><i>vibe coder</i></b>。</p>
          <p>我相信有机生长的力量 — 无论是社区、产品还是想法。我的驱动力是把混沌变成系统：标准化运营 SOP、设计增长漏斗、或者构建 AI 原生工作流，用可复用的知识替代重复性劳动。</p>
          <p>目前</p>
          <p>我在 <b>MEXC</b> 实习，担任现货运营专员。负责资源调配、活动全生命周期交付、数据分析，并搭建 AI 驱动的工作流（Claude Code + Obsidian），把几天的研究压缩到几小时。</p>
          <p>在做的事</p>
          <p>我在联合创建 <b>KitKit × Stello Agent</b>，一个 AI 原生的认知拓扑引擎。我负责小红书品牌运营、商业化策略和视觉设计 — 3 天内获得 3 万+ 曝光和 600+ 内测用户。</p>
          <p>背景</p>
          <p>中国民航大学在读（GPA 3.7/4.0），曾在香港大学商学院做研究。从零搭建过 Web3 社区，带领空投服务群创收 13 万+ 人民币，创立了一个 GMV 超 10 万的学生创业社区。</p>
        </article>
        <article class="lang-en hidden">
          <p>I am a <b><i>crypto operations specialist</i></b>, <b><i>community builder</i></b>, <b><i>product thinker</i></b>, <b><i>AI workflow explorer</i></b> and <b><i>vibe coder</i></b>.</p>
          <p>I believe in building things that grow organically — communities, products, and ideas. I'm driven by turning chaos into systems: whether it's standardizing operational SOPs, designing growth funnels, or crafting AI-native workflows that replace repetitive work with reusable knowledge.</p>
          <p>Currently</p>
          <p>I'm interning at <b>MEXC</b> as a spot operations specialist, where I manage resource allocation, campaign lifecycle delivery, data analysis, and build AI-powered workflows (Claude Code + Obsidian) that compress days of research into hours.</p>
          <p>Building</p>
          <p>I'm co-founding <b>KitKit × Stello Agent</b>, an AI-native cognitive topology engine. I lead Xiaohongshu brand operations, commercialization strategy, and visual identity — growing 30k+ impressions in 3 days and 600+ beta users.</p>
          <p>Background</p>
          <p>Student at Civil Aviation University of China (GPA 3.7/4.0), with a research stint at HKU Business School. I've built Web3 communities from zero, led airdrop service groups generating 130k+ RMB, and founded a student entrepreneurship community with 100k+ GMV.</p>
        </article>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              <span class="lang-zh">最新文章</span>
              <span class="lang-en hidden">Recent posts</span>
            </p>
            <a href="/blog" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                <span class="lang-zh">全部文章</span>
                <span class="lang-en hidden">All posts</span>
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            <span class="lang-zh">本站技术栈</span>
            <span class="lang-en hidden">Website build with</span>
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <div>
            <span class="lang-zh">响应式与状态管理由特邀嘉宾</span>
            <span class="lang-en hidden">Performing reactivity and statefulness, special guest</span>
            <a href="https://www.solidjs.com/" target="_blank" class="w-fit group underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                SolidJS
              </span>
            </a>
            <span class="lang-zh"> 提供支持</span>
            <span class="lang-en hidden"></span>
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              <span class="lang-zh">最新项目</span>
              <span class="lang-en hidden">Recent projects</span>
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                <span class="lang-zh">全部项目</span>
                <span class="lang-en hidden">All projects</span>
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            <span class="lang-zh">联系我</span>
            <span class="lang-en hidden">Let's Connect</span>
          </p>
          <p>
            <span class="lang-zh">通过邮件或社交媒体找到我。</span>
            <span class="lang-en hidden">Reach out to me via email or on social media.</span>
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                {social.HREF === "#wechat-qr" ? (
                  <button data-wechat-trigger class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend cursor-pointer">
                    <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                      {social.TEXT}
                    </span>
                  </button>
                ) : (
                  <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                    <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                      {social.TEXT}
                    </span>
                  </a>
                )}
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>

  <!-- WeChat QR Code Modal -->
  <div id="wechat-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="relative bg-white dark:bg-neutral-900 rounded-2xl p-6 mx-4 max-w-xs w-full shadow-2xl">
      <button id="wechat-modal-close" class="absolute top-3 right-3 size-8 flex items-center justify-center rounded-full hover:bg-black/10 dark:hover:bg-white/10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <p class="text-center font-semibold text-black dark:text-white mb-4">
        <span class="lang-zh">扫码加微信</span>
        <span class="lang-en hidden">Scan to add WeChat</span>
      </p>
      <img src="/wechat-qr.png" alt="WeChat QR Code" class="w-full rounded-lg" />
    </div>
  </div>

  <!-- WeChat Modal Script -->
  <script is:inline>
    function initWechatModal() {
      var modal = document.getElementById('wechat-modal');
      var closeBtn = document.getElementById('wechat-modal-close');
      if (!modal) return;
      document.querySelectorAll('[data-wechat-trigger]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
        });
      });
      if (closeBtn) closeBtn.addEventListener('click', function() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      });
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      });
    }
    document.addEventListener('astro:after-swap', initWechatModal);
    initWechatModal();
  </script>
</PageLayout>
