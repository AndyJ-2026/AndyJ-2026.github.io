---
import PageLayout from "@layouts/PageLayout.astro"
import { SITE } from "@consts"
---

<PageLayout title="404" description="Page not found">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center p-8">
      <!-- Sad penguin -->
      <div class="flex justify-center mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140" class="w-32 h-32 opacity-50">
          <ellipse cx="70" cy="85" rx="42" ry="38" fill="#d1d5db"/>
          <ellipse cx="70" cy="95" rx="30" ry="28" fill="#f5f5f4"/>
          <path d="M28 75 Q22 90 30 108 Q38 95 36 78Z" fill="#6b8fa3"/>
          <path d="M112 75 Q118 90 110 108 Q102 95 104 78Z" fill="#6b8fa3"/>
          <ellipse cx="70" cy="72" rx="35" ry="18" fill="#7a9bb0"/>
          <circle cx="70" cy="42" r="26" fill="#d1d5db"/>
          <path d="M50 38 Q55 52 70 56 Q85 52 90 38 Q82 44 70 46 Q58 44 50 38Z" fill="#f5f5f4"/>
          <path d="M44 38 Q48 16 70 14 Q92 16 96 38 Q88 24 70 22 Q52 24 44 38Z" fill="#1a2332"/>
          <!-- Sad eyes (looking down) -->
          <ellipse cx="58" cy="42" rx="4" ry="3" fill="white"/>
          <circle cx="58" cy="43" r="2" fill="#1a1a1a"/>
          <ellipse cx="82" cy="42" rx="4" ry="3" fill="white"/>
          <circle cx="82" cy="43" r="2" fill="#1a1a1a"/>
          <!-- Sad eyebrows -->
          <line x1="52" y1="36" x2="63" y2="34" stroke="#1a2332" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="88" y1="36" x2="77" y2="34" stroke="#1a2332" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M64 48 L70 62 L76 48Z" fill="#2c3e50"/>
          <line x1="58" y1="120" x2="55" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="58" y1="120" x2="61" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="82" y1="120" x2="79" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="82" y1="120" x2="85" y2="132" stroke="#d4956a" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </div>
      <h1 class="text-6xl font-bold text-black dark:text-white mb-4">404</h1>
      <p class="text-lg opacity-75 mb-8">
        <span class="lang-zh">页面走丢了...</span>
        <span class="lang-en hidden">Page not found...</span>
      </p>
      <a href="/" class="py-2 px-6 rounded bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend">
        <span class="lang-zh">回到首页</span>
        <span class="lang-en hidden">Back to Home</span>
      </a>
    </div>
  </div>
</PageLayout>
